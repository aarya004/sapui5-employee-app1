{
  "sap.app": {
    "id": "demo",
    "type": "application",
    "title": "Employee App",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },

  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },

  "sap.ui5": {
    "rootView": {
      "viewName": "demo.view.Main",
      "type": "XML",
      "async": true,
      "id": "app"
    },

    "dependencies": {
      "libs": {
        "sap.m": {}
      }
    },

    "models": {
      "": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/data.json"
      }
    }
  }
}
